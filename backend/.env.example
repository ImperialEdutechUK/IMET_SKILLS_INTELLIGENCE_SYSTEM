# ── Required ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"
# Secret used to sign/verify JWT auth tokens.
AUTH_SECRET="change-me-to-a-long-random-string"

# ── Recommendation engine (all OPTIONAL) ─────────────────────────────────────
# Core pipeline (parse → gap analysis → scoring) is deterministic and needs none
# of these. AI and external course sync activate only when configured.

# ── AI provider ──────────────────────────────────────────────────────────────
# One switch chooses the model that powers document analysis (skill extraction),
# skill normalisation, and the recommendation-chat reasoning. Leave every key
# blank to run the deterministic engine with no AI at all.
#   AI_PROVIDER: openrouter | deepseek | anthropic | gemini
#   (default: OpenRouter, then auto-detect the first configured key)
AI_PROVIDER="openrouter"

# OpenRouter — DEFAULT provider. One API key proxies to many models/providers
# (DeepSeek, Anthropic, OpenAI, Google…), so you manage billing/limits in one
# place and switch models by editing OPENROUTER_MODEL only.
# Get a key at https://openrouter.ai/keys — model ids look like
# "deepseek/deepseek-chat", "deepseek/deepseek-v4-pro", "anthropic/claude-sonnet-4.5".
#   • deepseek/deepseek-chat   → cheapest, non-reasoning, great for this engine
#   • deepseek/deepseek-v4-pro → a REASONING model: stronger, but pricier/slower
#     (it spends tokens "thinking" before the answer — the engine allows for this)
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="deepseek/deepseek-chat"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# DeepSeek direct (OpenAI-compatible). Only used if AI_PROVIDER="deepseek".
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL="deepseek-chat"
DEEPSEEK_BASE_URL="https://api.deepseek.com"

# Anthropic direct. Only used if AI_PROVIDER="anthropic".
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-5"

# Gemini (legacy option for skill extraction / normalisation / explanations)
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_MODEL_LITE="gemini-2.5-flash-lite"

# Upload storage directory
UPLOAD_DIR="./uploads"

# Apify (import scraped courses from a dataset — allowed domains only)
APIFY_TOKEN=""
APIFY_DATASET_ID=""
APIFY_ACTOR_ID=""
APIFY_ALLOWED_DOMAINS="edx.org,coursera.org,linkedin.com,futurelearn.com,udemy.com,open.edu"

# edX Discovery API (official OAuth2 client credentials)
EDX_CLIENT_ID=""
EDX_CLIENT_SECRET=""
EDX_API_BASE="https://api.edx.org"
EDX_DISCOVERY_BASE="https://discovery.edx.org"

# Placeholders — require official partner API access
COURSERA_BUSINESS_API_KEY=""
COURSERA_ORG_ID=""
LINKEDIN_LEARNING_API_TOKEN=""
LINKEDIN_LEARNING_ACCOUNT_ID=""
