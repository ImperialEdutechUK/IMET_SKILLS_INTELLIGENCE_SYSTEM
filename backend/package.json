{
  "name": "learnsmart-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "sync:coursera": "tsx --env-file=.env scripts/coursera-sync.ts",
    "sync:linkedin": "tsx --env-file=.env scripts/linkedin-learning-sync.ts",
    "cleanup:linkedin": "tsx --env-file=.env scripts/linkedin-cleanup.ts",
    "prune:non-english": "tsx --env-file=.env scripts/prune-non-english-courses.ts",
    "sync:edx": "tsx --env-file=.env scripts/edx-sync.ts",
    "sync:all": "tsx --env-file=.env scripts/sync-all.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "apify-client": "^2.9.3",
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.8.0",
    "next": "^16.2.10",
    "pdf-parse": "^1.1.1",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "19.2.17",
    "exceljs": "^4.4.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^2.1.8"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
